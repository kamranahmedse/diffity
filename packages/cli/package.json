  "bin": {
    "diffity": "./dist/index.js"
  },
  "scripts": {
    "build": "tsx build.ts",
    "dev": "tsx src/index.ts",
    "dev:watch": "tsx build.ts --watch"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
